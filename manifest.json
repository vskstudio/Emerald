{
  "manifest_version": 3,
  "name": "Emerald — Blackjack Strategy Overlay",
  "version": "1.0.0",
  "description": "Overlay visuel de stratégie Blackjack : recommandations Tirer / Rester / Doubler / Partager et probabilités en temps réel.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_title": "Emerald — Afficher/masquer l'overlay",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://duel.com/*", "https://*.duel.com/*"],
      "js": ["src/strategy.js", "src/detector.js", "src/content.js"],
      "css": ["src/overlay.css"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/icon48.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
